# RitZone Backend Environment Configuration Template
# ==============================================
# 🔒 SECURITY: Copy this file to .env and update with your values

# ==============================================
# 🗄️ SUPABASE CONFIGURATION
# ==============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ==============================================
# 🐘 POSTGRESQL DATABASE CONFIGURATION  
# ==============================================
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_CONNECTION_STRING=postgresql://postgres:password@host:5432/postgres

# ==============================================
# 🔐 SECURITY & JWT CONFIGURATION
# ==============================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
ENCRYPTION_KEY=your-encryption-key-here
SESSION_SECRET=your-session-secret-here

# ==============================================
# 🌐 SERVER CONFIGURATION
# ==============================================
BACKEND_PORT=8001
BACKEND_HOST=0.0.0.0
BACKEND_API_PREFIX=/api
NODE_ENV=development

# ==============================================
# 🎨 FRONTEND INTEGRATION
# ==============================================
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==============================================
# 📧 EMAIL CONFIGURATION (Optional)
# ==============================================
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ==============================================
# 💳 PAYMENT INTEGRATION (Optional)
# ==============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable

# ==============================================
# 📊 LOGGING & DEBUG
# ==============================================
LOG_LEVEL=info
DEBUG=false

# ======================================================
# 🔒 RATE LIMITING
# ==============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900

# ==============================================
# 👤 ADMIN CONFIGURATION
# ==============================================
ADMIN_DEFAULT_EMAIL=admin@ritzone.com
ADMIN_DEFAULT_PASSWORD=your-secure-admin-password